{
  "name": "mileclear",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @mileclear/api dev",
    "dev:web": "pnpm --filter @mileclear/web dev",
    "dev:mobile": "pnpm --filter @mileclear/mobile start",
    "build:api": "pnpm --filter @mileclear/api build",
    "build:web": "pnpm --filter @mileclear/web build",
    "build:shared": "pnpm --filter @mileclear/shared build",
    "db:migrate": "pnpm --filter @mileclear/api db:migrate",
    "db:generate": "pnpm --filter @mileclear/api db:generate",
    "db:studio": "pnpm --filter @mileclear/api db:studio",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @mileclear/shared test && pnpm --filter @mileclear/api test",
    "test:shared": "pnpm --filter @mileclear/shared test",
    "test:api": "pnpm --filter @mileclear/api test",
    "test:watch": "vitest --config vitest.config.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^15.5.15",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "prisma": "^6.19.2",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  },
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937"
}
