datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String?
  displayName      String?
  fullName         String?
  emailVerified    Boolean   @default(false)
  appleId          String?   @unique
  googleId         String?   @unique
  isPremium            Boolean   @default(false)
  isAdmin              Boolean   @default(false)
  premiumExpiresAt     DateTime?
  stripeCustomerId     String?   @unique @db.VarChar(255)
  stripeSubscriptionId String?   @unique @db.VarChar(255)
  appleOriginalTransactionId String? @unique @db.VarChar(255)
  termsAcceptedAt      DateTime?
  pushToken            String?   @db.VarChar(255)
  avatarId             String?   @db.VarChar(50)
  userIntent           String?   @db.VarChar(20)
  workType             String    @default("gig") @db.VarChar(20)
  employerMileageRatePence Int?
  dashboardMode        String    @default("both") @db.VarChar(20)
  notes                    String?   @db.Text
  lastLoginAt              DateTime?
  lastTripAt               DateTime?
  weeklyEarningsGoalPence  Int?

  // Marketing email opt-out. Defaults true (opt-out, not opt-in) - PECR allows
  // marketing to existing customers without explicit opt-in as long as they
  // have a clear, free way to opt out on every send (List-Unsubscribe header
  // + footer link). Transactional emails (verification, password reset,
  // billing, account deletion) ignore this flag.
  marketingEmailsEnabled Boolean @default(true)
  marketingEmailsDisabledAt DateTime?
  marketingEmailsDisabledSource String? @db.VarChar(32)

  // Heartbeat telemetry: updated once per app launch + every ~24h. Lets us
  // spot silent failures (e.g. users whose BG location permission was revoked
  // after onboarding) without needing a diagnostic dump from each one.
  lastHeartbeatAt       DateTime?
  bgLocationPermission  String?   @db.VarChar(32)
  notificationPermission String?  @db.VarChar(32)
  trackingTaskActive    Boolean?
  appVersion            String?   @db.VarChar(32)
  buildNumber           String?   @db.VarChar(32)
  osVersion             String?   @db.VarChar(32)
  // Sync-queue depth at time of last heartbeat. Lets admin detect stuck
  // queues per-user without waiting for a diagnostic dump. > 0 sustained
  // across heartbeats indicates the sync engine isn't draining.
  lastPendingSyncCount  Int?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  vehicles            Vehicle[]
  shifts              Shift[]
  trips               Trip[]
  fuelLogs            FuelLog[]
  earnings            Earning[]
  achievements        Achievement[]
  mileageSummary      MileageSummary[]
  refreshTokens       RefreshToken[]
  verificationCodes   VerificationCode[]
  passwordResetTokens PasswordResetToken[]
  plaidConnections    PlaidConnection[]
  feedback            Feedback[]
  feedbackVotes       FeedbackVote[]
  feedbackReplies     FeedbackReply[]
  savedLocations      SavedLocation[]
  tripAnomalies       TripAnomaly[]
  appEvents           AppEvent[]
  diagnosticDump      DiagnosticDump?
  expenses            Expense[]
  accountantInvites   AccountantInvite[]
  accountantAccess    AccountantAccess[]
  hmrcReconciliations HmrcReconciliation[]
  pickupWaits         PickupWait[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// User's reconciliation data: HMRC's reported earnings (per platform, per
// tax year, from the Digital Platform Reporting notice they receive)
// alongside what MileClear tracked. The diff goes on the dashboard so
// drivers can spot under- or over-reporting before HMRC does.
model HmrcReconciliation {
  id                String   @id @default(uuid())
  userId            String
  taxYear           String   @db.VarChar(7)  // e.g. "2025-26"
  platform          String   @db.VarChar(40) // platform tag value
  hmrcReportedPence Int
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taxYear, platform])
  @@index([userId, taxYear])
  @@map("hmrc_reconciliations")
}

// Pickup-point wait-time tracking. Drivers tap "I'm waiting" when they
// arrive at a restaurant / depot, then "Picked up" when the order's ready.
// Aggregated later to surface "this McDonald's averages 12-min waits"
// across all reporting drivers (privacy floor still applies).
model PickupWait {
  id              String    @id @default(uuid())
  userId          String
  locationName    String?   @db.VarChar(255) // reverse-geocoded
  locationLat     Float?
  locationLng     Float?
  platform        String?   @db.VarChar(40)
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?      // populated when endedAt is set
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([locationName])
  @@map("pickup_waits")
}

model Vehicle {
  id                String   @id @default(uuid())
  userId            String
  make              String
  model             String
  year              Int?
  fuelType          String
  vehicleType       String
  registrationPlate String?  @db.VarChar(10)
  bluetoothName     String?  @db.VarChar(100)
  estimatedMpg      Float?
  actualMpg         Float?
  isPrimary         Boolean  @default(true)
  createdAt         DateTime @default(now())

  // DVLA-sourced expiry data + reminder bookkeeping. Refreshed weekly by
  // the vehicle-reminders cron. Nullable for vehicles added before this
  // feature shipped or for vehicles without a registration plate.
  motExpiryDate     DateTime?
  taxDueDate        DateTime?
  lastDvlaCheckAt   DateTime?
  motReminderSentAt DateTime?
  taxReminderSentAt DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts   Shift[]
  trips    Trip[]
  fuelLogs FuelLog[]
  expenses Expense[]

  @@map("vehicles")
}

model Shift {
  id        String    @id @default(uuid())
  userId    String
  vehicleId String?
  startedAt DateTime
  endedAt   DateTime?
  status    String    @default("active")
  createdAt DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  trips   Trip[]

  @@map("shifts")
}

model Trip {
  id             String    @id @default(uuid())
  userId         String
  shiftId        String?
  vehicleId      String?
  startLat       Float
  startLng       Float
  endLat         Float?
  endLng         Float?
  startAddress   String?
  endAddress     String?
  distanceMiles  Float
  startedAt      DateTime
  endedAt        DateTime?
  isManualEntry  Boolean   @default(false)
  classification String    @default("unclassified")
  platformTag    String?
  businessPurpose String?
  category       String?
  notes          String?   @db.Text
  routePolyline  String?   @db.LongText

  // Per-trip GPS quality summary. JSON blob with raw/kept coord counts,
  // average accuracy metres, outliers filtered, which signal produced the
  // final distance. Used by the admin Trip Map and aggregate analytics.
  gpsQuality     Json?

  // Classification feedback loop: true if the user confirmed (or matched)
  // the auto-assigned classification, false if they changed it, null if the
  // trip was never auto-classified OR the user hasn't touched it yet.
  // Written once (API guards against overwrite) on the first user PATCH.
  classificationAutoAccepted Boolean?

  createdAt      DateTime  @default(now())
  syncedAt       DateTime?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift       Shift?            @relation(fields: [shiftId], references: [id])
  vehicle     Vehicle?          @relation(fields: [vehicleId], references: [id])
  coordinates TripCoordinate[]
  anomalies   TripAnomaly[]

  @@index([userId, startedAt])
  @@index([userId, classification])
  @@map("trips")
}

model TripCoordinate {
  id         String   @id @default(uuid())
  tripId     String
  lat        Float
  lng        Float
  speed      Float?
  accuracy   Float?
  recordedAt DateTime

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, recordedAt])
  @@map("trip_coordinates")
}

model TripAnomaly {
  id          String   @id @default(uuid())
  tripId      String
  userId      String
  type        String
  question    String   @db.Text
  response    String
  customNote  String?  @db.Text
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([lat, lng])
  @@map("trip_anomalies")
}

model FuelLog {
  id              String   @id @default(uuid())
  userId          String
  vehicleId       String?
  litres          Float
  costPence       Int
  stationName     String?
  odometerReading Float?
  latitude        Float?
  longitude       Float?
  loggedAt        DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([latitude, longitude])
  @@map("fuel_logs")
}

model Earning {
  id          String   @id @default(uuid())
  userId      String
  platform    String
  amountPence Int
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date
  source      String
  externalId  String?  @db.VarChar(255)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId])
  @@index([userId, periodStart])
  @@map("earnings")
}

model Achievement {
  id         String   @id @default(uuid())
  userId     String
  type       String
  achievedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("achievements")
}

model MileageSummary {
  id             String   @id @default(uuid())
  userId         String
  taxYear        String
  totalMiles     Float    @default(0)
  businessMiles  Float    @default(0)
  deductionPence Int      @default(0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taxYear])
  @@map("mileage_summaries")
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String
  code      String   @db.VarChar(6)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, used])
  @@map("verification_codes")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  code      String   @db.VarChar(6)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, used])
  @@map("password_reset_tokens")
}

model PlaidConnection {
  id              String    @id @default(uuid())
  userId          String
  institutionId   String?
  institutionName String?
  accessToken     String    @db.VarChar(500)
  refreshToken    String?   @db.VarChar(500)
  itemId          String    @unique
  lastSynced      DateTime?
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("plaid_connections")
}

model Feedback {
  id               String   @id @default(uuid())
  userId           String?
  displayName      String?  @db.VarChar(100)
  title            String   @db.VarChar(200)
  body             String   @db.Text
  category         String   @default("feature_request")
  status           String   @default("new")
  upvoteCount      Int      @default(0)
  isKnownIssue     Boolean  @default(false)
  knownIssueStatus String?  @db.VarChar(30)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  votes   FeedbackVote[]
  replies FeedbackReply[]

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([upvoteCount])
  @@index([isKnownIssue])
  @@map("feedback")
}

model FeedbackVote {
  id         String   @id @default(uuid())
  feedbackId String
  userId     String
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([feedbackId, userId])
  @@map("feedback_votes")
}

model FeedbackReply {
  id         String   @id @default(uuid())
  feedbackId String
  userId     String
  body       String   @db.Text
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
  @@map("feedback_replies")
}

model WaitlistEntry {
  id         String   @id @default(uuid())
  email      String   @unique
  driverType String?
  signedUpAt DateTime @default(now())

  @@map("waitlist")
}

model SavedLocation {
  id               String   @id @default(uuid())
  userId           String
  name             String
  locationType     String
  latitude         Float
  longitude        Float
  radiusMeters     Int      @default(150)
  geofenceEnabled  Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_locations")
}

model AppEvent {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(100)
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([createdAt])
  @@index([userId])
  @@map("app_events")
}

model DiagnosticDump {
  id          String   @id @default(uuid())
  userId      String   @unique
  capturedAt  DateTime
  platform    String   @db.VarChar(10)
  osVersion   String   @db.VarChar(20)
  appVersion  String   @db.VarChar(20)
  buildNumber String   @db.VarChar(20)
  verdict     String   @db.VarChar(20)
  statusJson  Json
  eventsJson  Json
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("diagnostic_dumps")
}

model Expense {
  id          String    @id @default(uuid())
  userId      String
  vehicleId   String?
  category    String    @db.VarChar(50)
  amountPence Int
  date        DateTime  @db.Date
  description String?   @db.VarChar(500)
  vendor      String?   @db.VarChar(200)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([userId, date])
  @@map("expenses")
}

model AccountantInvite {
  id        String   @id @default(uuid())
  userId    String
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(128)
  status    String   @default("pending") @db.VarChar(20)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([status, expiresAt])
  @@map("accountant_invites")
}

model AccountantAccess {
  id               String    @id @default(uuid())
  userId           String
  accountantEmail  String    @db.VarChar(255)
  token            String    @unique @db.VarChar(128)
  permissions      String    @default("read") @db.VarChar(50)
  lastAccessedAt   DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountantEmail])
  @@index([userId])
  @@map("accountant_access")
}

model AppleIapWebhookLog {
  id                    String   @id @default(uuid())
  notificationType      String?  @db.VarChar(100)
  subtype               String?  @db.VarChar(100)
  originalTransactionId String?  @db.VarChar(255)
  userId                String?
  environment           String?  @db.VarChar(20)
  status                String   @db.VarChar(30)
  errorMessage          String?  @db.Text
  receivedAt            DateTime @default(now())

  @@index([receivedAt])
  @@index([status, receivedAt])
  @@map("apple_iap_webhook_logs")
}

model JobRun {
  id           String    @id @default(uuid())
  jobName      String    @db.VarChar(100)
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String    @db.VarChar(20)
  errorMessage String?   @db.Text
  metadata     String?   @db.Text

  @@index([jobName, startedAt])
  @@index([startedAt])
  @@map("job_runs")
}
