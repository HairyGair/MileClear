datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String?
  displayName      String?
  fullName         String?
  emailVerified    Boolean   @default(false)
  appleId          String?   @unique
  googleId         String?   @unique
  isPremium            Boolean   @default(false)
  isAdmin              Boolean   @default(false)
  premiumExpiresAt     DateTime?
  stripeCustomerId     String?   @unique @db.VarChar(255)
  stripeSubscriptionId String?   @unique @db.VarChar(255)
  appleOriginalTransactionId String? @unique @db.VarChar(255)
  termsAcceptedAt      DateTime?
  pushToken            String?   @db.VarChar(255)
  avatarId             String?   @db.VarChar(50)
  userIntent           String?   @db.VarChar(20)
  workType             String    @default("gig") @db.VarChar(20)
  // Employer mileage reimbursement rate. employerMileageRatePence is the
  // first-10k-miles tier; employerMileageRatePenceAfter10k is the >10k tier.
  // If only the first-10k value is set, that rate applies to all miles
  // (single flat rate). Both are pence per mile. Used by mileage calculations
  // when workType is "employee" or "both" - falls back to HMRC AMAP otherwise.
  employerMileageRatePence Int?
  employerMileageRatePenceAfter10k Int?
  // Annual income from sources other than self-employed gig work (main job
  // salary, pension, rental income, etc.) in pence. Used to calculate the
  // marginal income-tax rate on gig profit so users with a £50k main job
  // see the correct 40% set-aside instead of an inaccurate basic-rate
  // estimate. NI bands stay independent (Class 4 NI is on profit only).
  // Optional: null = assume gig profit is the user's only taxable income.
  otherAnnualIncomePence Int?
  // PAYE tax already deducted by an employer this tax year (in pence).
  // For mixed PAYE+self-employed users, this is subtracted from the
  // Tax Readiness "owed" figure so they see what they still owe vs the
  // gross liability — otherwise the card double-counts tax their
  // employer has already collected. Laura Joyce request 10 May 2026.
  payeAnnualPaidTaxPence Int?
  // Accounting basis for tax computations. Cash-basis (the default since
  // April 2024 for most sole traders) counts income when received and
  // expenses when paid. Accruals counts when invoiced/billed regardless
  // of cash flow. Affects how Tax Readiness aggregates invoice income
  // (cash = paid invoices only; accruals = all sent invoices).
  taxBasis              String    @default("cash") @db.VarChar(16)
  // Accountant details. Laura Joyce request 11 May 2026: she pays an
  // accountant a known annual fee, wants MileClear to factor it into
  // the weekly set-aside guidance ("set aside her fee also"). Stored
  // as a free-text name + contact + the fee in pence. All optional —
  // users without an accountant skip the section entirely.
  accountantName            String?   @db.VarChar(120)
  accountantContact         String?   @db.VarChar(255)
  accountantAnnualFeePence  Int?
  dashboardMode        String    @default("both") @db.VarChar(20)
  notes                    String?   @db.Text
  lastLoginAt              DateTime?
  lastTripAt               DateTime?
  weeklyEarningsGoalPence  Int?

  // Marketing email opt-out. Defaults true (opt-out, not opt-in) - PECR allows
  // marketing to existing customers without explicit opt-in as long as they
  // have a clear, free way to opt out on every send (List-Unsubscribe header
  // + footer link). Transactional emails (verification, password reset,
  // billing, account deletion) ignore this flag.
  marketingEmailsEnabled Boolean @default(true)
  marketingEmailsDisabledAt DateTime?
  marketingEmailsDisabledSource String? @db.VarChar(32)

  // Heartbeat telemetry: updated once per app launch + every ~24h. Lets us
  // spot silent failures (e.g. users whose BG location permission was revoked
  // after onboarding) without needing a diagnostic dump from each one.
  lastHeartbeatAt       DateTime?
  bgLocationPermission  String?   @db.VarChar(32)
  notificationPermission String?  @db.VarChar(32)
  trackingTaskActive    Boolean?
  appVersion            String?   @db.VarChar(32)
  buildNumber           String?   @db.VarChar(32)
  osVersion             String?   @db.VarChar(32)
  // Sync-queue depth at time of last heartbeat. Lets admin detect stuck
  // queues per-user without waiting for a diagnostic dump. > 0 sustained
  // across heartbeats indicates the sync engine isn't draining.
  lastPendingSyncCount  Int?

  // 1.1.3+ heartbeat telemetry. Mobile started reporting these in build 58.
  // Each surfaces a different silent-failure mode that wasn't visible before:
  //
  //  - lastSyncQueueFailed/PermFailed: sync_queue rows in non-pending states.
  //    permanently_failed > 0 means trips that the sync engine has given up
  //    on - user's data won't reach the cloud without manual intervention.
  //  - secondsSinceLastTripPost: how long since their last trip reached the
  //    server. Identifies users where sync is silently broken even when
  //    queue counts look healthy.
  //  - daysSinceLastTrip: distinguishes active drivers from passive installs.
  //  - freeDiskBytes: low-disk users start losing SQLite writes silently.
  //  - backgroundFetchStatus: iOS Background App Refresh state. "denied" or
  //    "restricted" means the BACKGROUND_FINALIZE_TASK won't fire and
  //    tracking reliability tanks.
  lastSyncQueueFailed    Int?
  lastSyncQueuePermFailed Int?
  secondsSinceLastTripPost Int?
  daysSinceLastTrip       Int?
  freeDiskBytes           BigInt?
  backgroundFetchStatus   String?   @db.VarChar(16)

  // Watchdog state. Mobile reports recording state in heartbeat so the
  // server-side watchdog cron can spot stuck recordings even when the
  // device's own setInterval watchdog is suspended by iOS. Stale value
  // here triggers a silent push to wake the JS runtime and finalize.
  autoRecordingActive   Boolean?
  recordingStartedAt    DateTime?
  lastDrivingSpeedAt    DateTime?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  vehicles            Vehicle[]
  shifts              Shift[]
  trips               Trip[]
  fuelLogs            FuelLog[]
  earnings            Earning[]
  achievements        Achievement[]
  mileageSummary      MileageSummary[]
  refreshTokens       RefreshToken[]
  verificationCodes   VerificationCode[]
  passwordResetTokens PasswordResetToken[]
  plaidConnections    PlaidConnection[]
  feedback            Feedback[]
  feedbackVotes       FeedbackVote[]
  feedbackReplies     FeedbackReply[]
  savedLocations      SavedLocation[]
  tripAnomalies       TripAnomaly[]
  appEvents           AppEvent[]
  diagnosticDump      DiagnosticDump?
  expenses            Expense[]
  accountantInvites   AccountantInvite[]
  accountantAccess    AccountantAccess[]
  hmrcReconciliations HmrcReconciliation[]
  pickupWaits         PickupWait[]
  hmrcConnection      HmrcConnection?
  invoices            Invoice[]

  @@map("users")
}

// MTD ITSA OAuth connection. One per user - they grant MileClear permission
// to read + write their HMRC tax account via the Self Employment Business
// API. Tokens stored server-side; mobile asks the API "am I connected?" and
// kicks off the OAuth flow when not. Phase 1 of the MTD ITSA build (week of
// 5 May 2026), see [mtd_itsa_plan.md].
model HmrcConnection {
  id             String   @id @default(uuid())
  userId         String   @unique
  // Encrypted at rest (TODO once Phase 4 accreditation lands; sandbox-only
  // for now so plaintext is acceptable for the next 4-6 weeks).
  accessToken    String   @db.Text
  refreshToken   String   @db.Text
  // Space-separated OAuth scope string returned by HMRC.
  scope          String   @db.Text
  // Sandbox or Production. Once production accreditation lands a single
  // user might still be on sandbox during testing — recorded per-row so
  // the right base URL is used on every API call.
  environment    String   @db.VarChar(16)
  expiresAt      DateTime
  // The state token we generated for the OAuth handshake. Verified on
  // callback to prevent CSRF.
  lastStateToken String?  @db.VarChar(64)
  // National Insurance Number — required as a path parameter on most MTD
  // endpoints. We collect it post-OAuth via /hmrc/nino. Format validated
  // against the UK NINO regex (^[A-CEGHJ-PR-TW-Z]{2}\d{6}[A-D ]?$).
  nino           String?  @db.VarChar(13)
  // HMRC business ID for the user's self-employment trade. Returned by the
  // Self Employment Business API once the trade is registered with HMRC.
  // Single-business assumption for MileClear (one self-employment trade
  // per user) — we'll revisit if a user has multiple businesses.
  businessId     String?  @db.VarChar(40)
  connectedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  // Set when the user disconnects, OR when HMRC returns invalid_grant on
  // refresh (token revoked at HMRC's end). Null = currently active.
  disconnectedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hmrc_connections")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Token-family replay detection (12 May 2026, Laura Joyce bug).
  // Refresh tokens are rotated on each /auth/refresh — but the network
  // can drop the response mid-flight (iOS process suspension being the
  // most common cause), leaving the client with the old token while
  // the server has issued a new one. To handle this without false
  // logouts, we keep old tokens linked to their successors:
  //
  //   familyId        — shared across every rotation chain stemming
  //                     from a single login. Lets us revoke an entire
  //                     family in one query when replay is detected.
  //   rotatedToTokenId — set when a token has been rotated forward.
  //                     Points to its immediate successor.
  //   revokedAt       — set on every member of a family that's been
  //                     killed (manual logout, family replay detected).
  //
  // Refresh logic:
  //   - rotatedToTokenId IS NULL  → head of chain. Rotate normally.
  //   - rotatedToTokenId set, successor IS still head → grace path.
  //     Rotate the successor forward, return its replacement. The
  //     stale presenter (legitimate client that missed an ack) gets
  //     recovered seamlessly.
  //   - rotatedToTokenId set, successor IS ALSO rotated → REPLAY.
  //     The presenter is using a token >= 2 generations old, which
  //     a legitimate client never does. Revoke the entire family.
  //
  // familyId migrated to NOT NULL with a backfill that uses the row's
  // own id as the family for existing tokens (each pre-migration token
  // becomes its own one-row family — equivalent to old behaviour).
  familyId         String   @db.VarChar(191)
  rotatedToTokenId String?  @db.VarChar(191)
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@map("refresh_tokens")
}

// User's reconciliation data: HMRC's reported earnings (per platform, per
// tax year, from the Digital Platform Reporting notice they receive)
// alongside what MileClear tracked. The diff goes on the dashboard so
// drivers can spot under- or over-reporting before HMRC does.
model HmrcReconciliation {
  id                String   @id @default(uuid())
  userId            String
  taxYear           String   @db.VarChar(7)  // e.g. "2025-26"
  platform          String   @db.VarChar(40) // platform tag value
  hmrcReportedPence Int
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taxYear, platform])
  @@index([userId, taxYear])
  @@map("hmrc_reconciliations")
}

// Pickup-point wait-time tracking. Drivers tap "I'm waiting" when they
// arrive at a restaurant / depot, then "Picked up" when the order's ready.
// Aggregated later to surface "this McDonald's averages 12-min waits"
// across all reporting drivers (privacy floor still applies).
model PickupWait {
  id              String    @id @default(uuid())
  userId          String
  locationName    String?   @db.VarChar(255) // reverse-geocoded
  locationLat     Float?
  locationLng     Float?
  platform        String?   @db.VarChar(40)
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?      // populated when endedAt is set
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([locationName])
  @@map("pickup_waits")
}

model Vehicle {
  id                String   @id @default(uuid())
  userId            String
  make              String
  model             String
  year              Int?
  fuelType          String
  vehicleType       String
  registrationPlate String?  @db.VarChar(10)
  bluetoothName     String?  @db.VarChar(100)
  estimatedMpg      Float?
  actualMpg         Float?
  isPrimary         Boolean  @default(true)
  createdAt         DateTime @default(now())

  // DVLA-sourced expiry data + reminder bookkeeping. Refreshed weekly by
  // the vehicle-reminders cron. Nullable for vehicles added before this
  // feature shipped or for vehicles without a registration plate.
  motExpiryDate     DateTime?
  taxDueDate        DateTime?
  lastDvlaCheckAt   DateTime?
  motReminderSentAt DateTime?
  taxReminderSentAt DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts   Shift[]
  trips    Trip[]
  fuelLogs FuelLog[]
  expenses Expense[]

  @@map("vehicles")
}

model Shift {
  id        String    @id @default(uuid())
  userId    String
  vehicleId String?
  startedAt DateTime
  endedAt   DateTime?
  status    String    @default("active")
  createdAt DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  trips   Trip[]

  @@map("shifts")
}

model Trip {
  id             String    @id @default(uuid())
  userId         String
  shiftId        String?
  vehicleId      String?
  startLat       Float
  startLng       Float
  endLat         Float?
  endLng         Float?
  startAddress   String?
  endAddress     String?
  distanceMiles  Float
  startedAt      DateTime
  endedAt        DateTime?
  isManualEntry  Boolean   @default(false)
  classification String    @default("unclassified")
  platformTag    String?
  businessPurpose String?
  category       String?
  notes          String?   @db.Text
  routePolyline  String?   @db.LongText

  // Per-trip GPS quality summary. JSON blob with raw/kept coord counts,
  // average accuracy metres, outliers filtered, which signal produced the
  // final distance. Used by the admin Trip Map and aggregate analytics.
  gpsQuality     Json?

  // Classification feedback loop: true if the user confirmed (or matched)
  // the auto-assigned classification, false if they changed it, null if the
  // trip was never auto-classified OR the user hasn't touched it yet.
  // Written once (API guards against overwrite) on the first user PATCH.
  classificationAutoAccepted Boolean?

  // Phantom-trip flag (4 May 2026). Set when an auto-detected trip
  // matches the walking-speed signature (distance < 1mi, duration > 5min,
  // avg speed < 5mph). Filtered out of all user-facing queries +
  // analytics aggregates so users never see them, but preserved in the
  // DB for diagnostic review.
  isPhantomTrip  Boolean   @default(false)

  createdAt      DateTime  @default(now())
  syncedAt       DateTime?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift       Shift?            @relation(fields: [shiftId], references: [id])
  vehicle     Vehicle?          @relation(fields: [vehicleId], references: [id])
  coordinates TripCoordinate[]
  anomalies   TripAnomaly[]

  @@index([userId, startedAt])
  @@index([userId, classification])
  @@map("trips")
}

model TripCoordinate {
  id         String   @id @default(uuid())
  tripId     String
  lat        Float
  lng        Float
  speed      Float?
  accuracy   Float?
  recordedAt DateTime

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, recordedAt])
  @@map("trip_coordinates")
}

model TripAnomaly {
  id          String   @id @default(uuid())
  tripId      String
  userId      String
  type        String
  question    String   @db.Text
  response    String
  customNote  String?  @db.Text
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([lat, lng])
  @@map("trip_anomalies")
}

model FuelLog {
  id              String   @id @default(uuid())
  userId          String
  vehicleId       String?
  litres          Float
  costPence       Int
  stationName     String?
  odometerReading Float?
  latitude        Float?
  longitude       Float?
  loggedAt        DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([latitude, longitude])
  @@map("fuel_logs")
}

model Earning {
  id          String   @id @default(uuid())
  userId      String
  platform    String
  amountPence Int
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date
  source      String
  externalId  String?  @db.VarChar(255)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Reverse side of Invoice.linkedEarningId. When an invoice is linked
  // to this earning, the Tax Readiness aggregator counts the invoice
  // and skips the earning to prevent double-counting.
  linkedInvoices Invoice[]

  @@unique([userId, externalId])
  @@index([userId, periodStart])
  @@map("earnings")
}

model Achievement {
  id         String   @id @default(uuid())
  userId     String
  type       String
  achievedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("achievements")
}

model MileageSummary {
  id             String   @id @default(uuid())
  userId         String
  taxYear        String
  totalMiles     Float    @default(0)
  businessMiles  Float    @default(0)
  deductionPence Int      @default(0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taxYear])
  @@map("mileage_summaries")
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String
  code      String   @db.VarChar(6)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, used])
  @@map("verification_codes")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  code      String   @db.VarChar(6)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, used])
  @@map("password_reset_tokens")
}

model PlaidConnection {
  id              String    @id @default(uuid())
  userId          String
  institutionId   String?
  institutionName String?
  accessToken     String    @db.Text
  refreshToken    String?   @db.Text
  itemId          String    @unique
  lastSynced      DateTime?
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("plaid_connections")
}

model Feedback {
  id               String   @id @default(uuid())
  userId           String?
  displayName      String?  @db.VarChar(100)
  title            String   @db.VarChar(200)
  body             String   @db.Text
  category         String   @default("feature_request")
  status           String   @default("new")
  upvoteCount      Int      @default(0)
  isKnownIssue     Boolean  @default(false)
  knownIssueStatus String?  @db.VarChar(30)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  votes   FeedbackVote[]
  replies FeedbackReply[]

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([upvoteCount])
  @@index([isKnownIssue])
  @@map("feedback")
}

model FeedbackVote {
  id         String   @id @default(uuid())
  feedbackId String
  userId     String
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([feedbackId, userId])
  @@map("feedback_votes")
}

model FeedbackReply {
  id         String   @id @default(uuid())
  feedbackId String
  userId     String
  body       String   @db.Text
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
  @@map("feedback_replies")
}

model WaitlistEntry {
  id         String   @id @default(uuid())
  email      String   @unique
  driverType String?
  signedUpAt DateTime @default(now())

  @@map("waitlist")
}

model SavedLocation {
  id               String   @id @default(uuid())
  userId           String
  name             String
  locationType     String
  latitude         Float
  longitude        Float
  radiusMeters     Int      @default(100)
  geofenceEnabled  Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_locations")
}

model AppEvent {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(100)
  userId    String?
  metadata  Json?
  // Build-attribution for per-build regression detection (audit follow-up,
  // 4 May 2026). Captured at event time from the user's most-recent
  // heartbeat. Null on events with no userId, or events from before this
  // column was added. See /admin/build-health for the rollup view.
  appVersion  String? @db.VarChar(32)
  buildNumber String? @db.VarChar(32)
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([createdAt])
  @@index([userId])
  // For per-build regression queries: filter by build, group by type.
  @@index([buildNumber, type, createdAt])
  @@map("app_events")
}

model DiagnosticDump {
  id          String   @id @default(uuid())
  userId      String   @unique
  capturedAt  DateTime
  platform    String   @db.VarChar(10)
  osVersion   String   @db.VarChar(20)
  appVersion  String   @db.VarChar(20)
  buildNumber String   @db.VarChar(20)
  verdict     String   @db.VarChar(20)
  statusJson  Json
  eventsJson  Json
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("diagnostic_dumps")
}

model Expense {
  id          String    @id @default(uuid())
  userId      String
  vehicleId   String?
  category    String    @db.VarChar(50)
  amountPence Int
  date        DateTime  @db.Date
  description String?   @db.VarChar(500)
  vendor      String?   @db.VarChar(200)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([userId, date])
  @@map("expenses")
}

model AccountantInvite {
  id        String   @id @default(uuid())
  userId    String
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(128)
  status    String   @default("pending") @db.VarChar(20)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([status, expiresAt])
  @@map("accountant_invites")
}

model AccountantAccess {
  id               String    @id @default(uuid())
  userId           String
  accountantEmail  String    @db.VarChar(255)
  token            String    @unique @db.VarChar(128)
  permissions      String    @default("read") @db.VarChar(50)
  lastAccessedAt   DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountantEmail])
  @@index([userId])
  @@map("accountant_access")
}

model AppleIapWebhookLog {
  id                    String   @id @default(uuid())
  notificationType      String?  @db.VarChar(100)
  subtype               String?  @db.VarChar(100)
  originalTransactionId String?  @db.VarChar(255)
  userId                String?
  environment           String?  @db.VarChar(20)
  status                String   @db.VarChar(30)
  errorMessage          String?  @db.Text
  receivedAt            DateTime @default(now())

  @@index([receivedAt])
  @@index([status, receivedAt])
  @@map("apple_iap_webhook_logs")
}

// Marker that an Apple originalTransactionId has been confirmed as a
// ghost: a sandbox subscription with no matching MileClear user (deleted
// TestFlight tester, pre-appAccountToken purchase, etc). Once flagged,
// every webhook log row for that txn is filtered out of the admin
// "Last 24h" chip and the orphan reprocess loop. The row stays in the
// log for audit, but stops counting as noise.
model AppleIapGhost {
  originalTransactionId String   @id @db.VarChar(255)
  dismissedAt           DateTime @default(now())
  dismissedBy           String?  // user id of the admin who marked it
  reason                String?  @db.Text

  @@map("apple_iap_ghosts")
}

model JobRun {
  id           String    @id @default(uuid())
  jobName      String    @db.VarChar(100)
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String    @db.VarChar(20)
  errorMessage String?   @db.Text
  metadata     String?   @db.Text

  @@index([jobName, startedAt])
  @@index([startedAt])
  @@map("job_runs")
}

// Crowd-sourced geofence radius observations. Each finalised geofence-
// triggered trip reports the distance from the saved-location pin to
// the first driving-speed GPS coord. A weekly cron rolls these up into
// per-location-type percentiles, which the mobile app reads back as
// "recommended radius" when the user creates a new saved location.
//
// Why: the static 200m default is wrong for cul-de-sacs (too tight) and
// busy roads (too loose). The aggregate of "where does driving actually
// start from this kind of location?" gives a better default per type.
//
// Privacy: only the location_type + distance is rolled up. The userId
// is kept for dedup but never returned in the recommended-radius API.
// 4 May 2026 — server foundation; mobile reporting + reads pair with a
// deliberate mobile-side change.
model GeofenceRadiusObservation {
  id                String   @id @default(uuid())
  userId            String
  /** Saved-location type at observation time: home / work / depot / custom. */
  locationType      String   @db.VarChar(16)
  /** Distance in metres from the saved-location pin to the first driving-
   *  speed coord on the trip that exited that geofence. */
  distanceMeters    Float
  recordedAt        DateTime @default(now())

  @@index([locationType, recordedAt])
  @@index([userId, recordedAt])
  @@map("geofence_radius_observations")
}

// Rolled-up recommendation per location_type. Refreshed by a weekly
// cron from the observations table. Mobile reads these on saved-
// location load.
model GeofenceRadiusRecommendation {
  /** Use locationType as the primary key. Avoids MySQL's "two NULL
   *  countryCodes are distinct" quirk if we'd added country dimension.
   *  Per-region partitioning can land later via a separate table. */
  locationType    String   @id @db.VarChar(16)
  /** 75th percentile distance in metres — the radius the mobile should
   *  default to so 75% of geofence-triggered trips fall inside it. */
  p75Meters       Float
  /** Sample size that fed in. Below ~50 we don't trust the percentile
   *  and the mobile falls back to the static 200m default. */
  sampleSize      Int
  computedAt      DateTime @default(now())

  @@map("geofence_radius_recommendations")
}

// Persistent cache of computed road distances between (start, end)
// coordinate pairs. Once any route is computed (by GraphHopper or Google),
// every future request for the same coords returns the cached value
// regardless of which engine produced it. This is the foundation that
// makes "user manually adds three trips A→B and the miles match" a
// structural guarantee, not a hopeful coincidence.
//
// Coords stored rounded to 4 decimal places (~11 m precision) so trivial
// drift in user-entered addresses still hits the cache. The composite
// unique key is (startLatRounded, startLngRounded, endLatRounded, endLngRounded).
//
// Source enum:
//   "graphhopper" — self-hosted GraphHopper on Pixelish (preferred)
//   "google"       — Google Maps Routes API fallback
// Never cache haversine fallbacks — those should never reach the user
// without explicit opt-in.
//
// Bug fix shipped 10 May 2026 after Laura Joyce reported MileClear's
// manual trips with identical addresses returned different mileages
// (silent OSRM-failure → haversine fallback). See docs/routing-stack.md.
model RouteCache {
  id                  String   @id @default(uuid())
  startLatRounded     Float
  startLngRounded     Float
  endLatRounded       Float
  endLngRounded       Float
  distanceMiles       Float
  durationSecs        Int
  source              String   @db.VarChar(20)  // "graphhopper" | "google"
  computedAt          DateTime @default(now())
  hitCount            Int      @default(0)     // bumped on each cache hit
  lastHitAt           DateTime?

  @@unique([startLatRounded, startLngRounded, endLatRounded, endLngRounded], map: "route_cache_coords_uk")
  @@index([computedAt])
  @@map("route_cache")
}

// Sole-trader invoice tracker. Shipped 10 May 2026 from Laura Joyce
// feedback — drivers who freelance on the side need a clean list of
// "who owes me, who's paid me, what's overdue" that they can hand to
// their accountant. Deliberately NOT a Xero-style collections workflow
// (Late Payment of Commercial Debts Act helper, formal letter generator
// etc. were considered but Laura's feedback was "no idea what that is",
// confirming most users want simple list + accountant export, not a
// finance product).
//
// Tax basis interaction:
//  - cash basis (default): Tax Readiness counts only paidAt-set invoices
//  - accruals: Tax Readiness counts every status != "written_off"
// The toggle lives on User.taxBasis.
model Invoice {
  id          String   @id @default(uuid())
  userId      String
  /** Free-text company / client name. */
  company     String   @db.VarChar(200)
  /** Optional reference for the user's own bookkeeping (PO numbers,
   *  job numbers, etc). */
  reference   String?  @db.VarChar(80)
  /** Total amount in pence (gross — VAT handling deferred to a Pro
   *  feature). */
  amountPence Int
  /** Date the invoice was sent / issued. */
  sentAt      DateTime @db.Date
  /** Calculated as sentAt + 30 days unless the user overrides. UK
   *  Late Payment of Commercial Debts Act sets 30 days as the default
   *  trigger for late-payment interest entitlement. */
  dueAt       DateTime @db.Date
  /** When the money was actually received. Drives cash-basis tax
   *  calculations. Null until the user marks it paid. */
  paidAt      DateTime? @db.Date
  /** One of: sent, paid, overdue, written_off. Computed at save time
   *  from paidAt + dueAt; cached here so list filters are cheap. */
  status      String    @default("sent") @db.VarChar(16)
  notes       String?   @db.Text
  /** Optional link to the manual Earning row that represents the same
   *  money. When set, the Tax Readiness aggregator counts the invoice
   *  and skips the linked earning — prevents the double-counting trap
   *  where a freelancer logs both a gig-style earning AND an invoice
   *  for the same job (Laura Joyce case, 21 May 2026).
   *  ON DELETE SET NULL: if the earning is removed, the invoice stays
   *  intact and just unlinks. Many invoices may share one earning (a
   *  user who logged a quarterly total as a single earning and later
   *  added per-job invoices for the same period). */
  linkedEarningId String?  @db.VarChar(36)
  linkedEarning   Earning? @relation(fields: [linkedEarningId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, sentAt])
  @@index([linkedEarningId])
  @@map("invoices")
}

// Idempotency keys for safe retry of mutation requests. When a client
// sends an `Idempotency-Key` header, the server caches the response
// for the TTL window. Subsequent requests with the same key return the
// cached response without re-executing the handler.
//
// Audit item #3 (external_audit_may_2.md). 24-hour TTL; expired rows
// purged hourly by a cron job.
model IdempotencyKey {
  id           String   @id @default(uuid())
  userId       String
  key          String   @db.VarChar(128)
  method       String   @db.VarChar(10)
  path         String   @db.VarChar(255)
  statusCode   Int
  responseBody String   @db.LongText
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([userId, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}
