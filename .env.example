# Database
DATABASE_URL="mysql://user:password@localhost:3306/mileclear"

# JWT
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# API
API_PORT=3002
API_HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:3003"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3002"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_APPLE_CLIENT_ID=""

# Email (Brevo SMTP)
BREVO_SMTP_USER="your-brevo-login-email"
BREVO_SMTP_KEY="your-brevo-smtp-key"
EMAIL_FROM="noreply@mileclear.com"

# Apple Sign-In
APPLE_CLIENT_ID=""          # iOS bundle ID (com.mileclear.app)
APPLE_WEB_CLIENT_ID=""      # Web Services ID (com.mileclear.web)
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# Google Sign-In
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# API Base URL (used for Stripe Checkout redirect URLs)
API_BASE_URL="https://api.mileclear.com"

# Apple In-App Purchase (App Store Server API v2)
APPLE_IAP_KEY_ID=""           # Key ID from App Store Connect (Users & Access → Integrations → In-App Purchase)
APPLE_IAP_ISSUER_ID=""        # Issuer ID from App Store Connect
APPLE_IAP_PRIVATE_KEY=""      # Base64-encoded .p8 private key (cat key.p8 | base64)
APPLE_IAP_BUNDLE_ID="com.mileclear.app"
APPLE_IAP_ENVIRONMENT="Sandbox"  # "Sandbox" or "Production"

# APNs — push-to-start Live Activities (Dynamic Island auto-appears on a
# background-detected drive). Separate Apple key from IAP. Generate at
# developer.apple.com → Keys → new key with Apple Push Notifications service.
APNS_KEY_ID=""                # Key ID of the APNs Auth Key
APNS_TEAM_ID=""               # Apple Developer Team ID
APNS_BUNDLE_ID="com.mileclear.app"
APNS_KEY_PATH=""              # Absolute path to the .p8 file (server secret, never commit)
# APNS_KEY_BASE64=""          # Alternative to APNS_KEY_PATH: base64 of the .p8 (cat key.p8 | base64)
# APNS_HOST="api.push.apple.com"  # Override to api.sandbox.push.apple.com for Xcode debug builds only

# Redis (optional)
REDIS_URL="redis://localhost:6379"

# DVLA Vehicle Enquiry Service
DVLA_API_KEY=""   # Register at developer-portal.driver-vehicle-licensing.api.gov.uk

# TrueLayer (Open Banking)
TRUELAYER_CLIENT_ID=""
TRUELAYER_CLIENT_SECRET=""
TRUELAYER_ENV="sandbox"
TRUELAYER_REDIRECT_URI=""  # Defaults to API_BASE_URL/earnings/open-banking/callback

# Fuel Finder API (UK Government — all 8,300+ stations)
FUEL_FINDER_CLIENT_ID=""         # OAuth 2.0 client ID from developer portal
FUEL_FINDER_CLIENT_SECRET=""     # OAuth 2.0 client secret
FUEL_FINDER_TOKEN_URL="https://www.fuel-finder.service.gov.uk/api/v1/oauth/generate_secret_token"
FUEL_FINDER_API_BASE_URL="https://api.fuelfinder.service.gov.uk"

# Open Charge Map — nearby EV chargers. Free API key from openchargemap.org
# (register an app). Feature no-ops gracefully if unset. CC BY 4.0 — attribution
# shown in-app. Octopus electricity-rate suggestion needs no key.
OPEN_CHARGE_MAP_API_KEY=""

# HMRC Making Tax Digital — ITSA (Phase 1+, MTD ITSA build)
# Application registered at developer.service.hmrc.uk
# Application ID: 1f34acb9-8580-464b-a337-24fd318d7ac7 (sandbox)
# Retrieve Client ID + Secret from the application's "Authorisation Details"
# section. Production credentials require HMRC Software Application Review
# (Phase 4 of the MTD plan, ~3-4 weeks).
HMRC_CLIENT_ID=""
HMRC_CLIENT_SECRET=""
HMRC_ENVIRONMENT="sandbox"  # "sandbox" or "production"
HMRC_REDIRECT_URI=""        # Defaults to API_BASE_URL/hmrc/callback
# Vendor identification for fraud-prevention headers (Gov-Vendor-*).
HMRC_VENDOR_PRODUCT_NAME="MileClear"
HMRC_VENDOR_VERSION="1.2.0"
HMRC_VENDOR_LICENSE_IDS=""  # If applicable; usually empty for direct vendors

# Discord channel webhooks (outbound posts from API to community server).
# Each is a webhook URL from Discord:
#   Server → channel → Edit Channel → Integrations → Webhooks → New Webhook
#   → name it "MileClear" → upload bot-avatar.png → Copy Webhook URL
# Webhooks are URL-only credentials (no bot token needed) and scope to a
# single channel. Leaving any of these unset silently skips that channel's
# posts — the API never errors over a missing Discord webhook.
DISCORD_WEBHOOK_WHATSNEW=""        # #whats-new — build/release announcements
DISCORD_WEBHOOK_ANNOUNCEMENTS=""   # #announcements — App Store reviews, milestones
DISCORD_WEBHOOK_WINS=""            # #wins — public Pro signups, milestones
DISCORD_WEBHOOK_BOTLOGS=""         # #bot-logs — server-side event log
DISCORD_WEBHOOK_MODCHAT=""         # #mod-chat — actionable moderation alerts (abuse, spam, ToS)
DISCORD_WEBHOOK_FOUNDER=""         # #founder — founder-only telemetry (watchdog, IAP orphans, payment fails). Falls back to MODCHAT if unset.
DISCORD_WEBHOOK_TAXTIPS=""         # #tax-and-hmrc — daily tax tip of the day

# Discord bot (for scripts + role management). Used by:
#   - scripts/discord-bootstrap.mjs       (one-time, role + channel creation)
#   - scripts/discord-create-webhooks.mjs (one-time, webhook creation)
#   - apps/api/src/services/discordBot.ts (Pro Member role auto-sync)
# Get the token from Discord Developer Portal → Bot tab → Reset Token.
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""                # MileClear server ID

# Discord role auto-sync — the Pro Member role gets granted/revoked
# automatically based on User.isPremium. Role ID from Server Settings
# → Roles → click Pro Member → ⋯ → Copy Role ID (Developer Mode on).
DISCORD_PRO_ROLE_ID=""

# Discord OAuth (the "Link your account" flow in the mobile app).
# Client ID + Secret from Developer Portal → OAuth2 tab.
# Redirect URI defaults to API_BASE_URL/auth/discord/callback; override
# only if the API isn't reachable at that path (e.g. tunnelled dev).
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_OAUTH_REDIRECT_URI=""

# Discord interactions (slash commands) — Ed25519 signature verification
# uses the application's Public Key from Developer Portal → General
# Information. Different from Client Secret; safe to share.
DISCORD_PUBLIC_KEY=""

# QuickBooks Online (Pro-only export integration)
# Application registered at developer.intuit.com — sandbox keys work
# immediately; production keys require Intuit's app review (~2-4 weeks).
# Scope: com.intuit.quickbooks.accounting
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_ENVIRONMENT="sandbox"  # "sandbox" or "production"
QUICKBOOKS_REDIRECT_URI=""        # Defaults to API_BASE_URL/quickbooks/callback

# Node environment
NODE_ENV="development"
