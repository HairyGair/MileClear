# Database
DATABASE_URL="mysql://user:password@localhost:3306/mileclear"

# JWT
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# API
API_PORT=3002
API_HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:3003"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3002"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_APPLE_CLIENT_ID=""

# Email (Brevo SMTP)
BREVO_SMTP_USER="your-brevo-login-email"
BREVO_SMTP_KEY="your-brevo-smtp-key"
EMAIL_FROM="noreply@mileclear.com"

# Apple Sign-In
APPLE_CLIENT_ID=""          # iOS bundle ID (com.mileclear.app)
APPLE_WEB_CLIENT_ID=""      # Web Services ID (com.mileclear.web)
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# Google Sign-In
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# API Base URL (used for Stripe Checkout redirect URLs)
API_BASE_URL="https://api.mileclear.com"

# Apple In-App Purchase (App Store Server API v2)
APPLE_IAP_KEY_ID=""           # Key ID from App Store Connect (Users & Access → Integrations → In-App Purchase)
APPLE_IAP_ISSUER_ID=""        # Issuer ID from App Store Connect
APPLE_IAP_PRIVATE_KEY=""      # Base64-encoded .p8 private key (cat key.p8 | base64)
APPLE_IAP_BUNDLE_ID="com.mileclear.app"
APPLE_IAP_ENVIRONMENT="Sandbox"  # "Sandbox" or "Production"

# Redis (optional)
REDIS_URL="redis://localhost:6379"

# DVLA Vehicle Enquiry Service
DVLA_API_KEY=""   # Register at developer-portal.driver-vehicle-licensing.api.gov.uk

# TrueLayer (Open Banking)
TRUELAYER_CLIENT_ID=""
TRUELAYER_CLIENT_SECRET=""
TRUELAYER_ENV="sandbox"
TRUELAYER_REDIRECT_URI=""  # Defaults to API_BASE_URL/earnings/open-banking/callback

# Fuel Finder API (UK Government — all 8,300+ stations)
FUEL_FINDER_CLIENT_ID=""         # OAuth 2.0 client ID from developer portal
FUEL_FINDER_CLIENT_SECRET=""     # OAuth 2.0 client secret
FUEL_FINDER_TOKEN_URL="https://www.fuel-finder.service.gov.uk/api/v1/oauth/generate_secret_token"
FUEL_FINDER_API_BASE_URL="https://api.fuelfinder.service.gov.uk"

# Node environment
NODE_ENV="development"
